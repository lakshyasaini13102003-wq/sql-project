select*from finance_economics_dataset where Stock_Index='Dow Jones' and Trading_Volume > 2670411;

 select*from finance_economics_dataset where Stock_Index='Dow Jones' and Trading_Volume>13098297;

 --or clause--

 select*from finance_economics_dataset where Stock_Index='Dow Jones' or Trading_Volume > 2670411;

