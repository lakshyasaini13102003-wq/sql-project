select Stock_Index,Daily_low, max (Open_Price) as total_revenue from finance_economics_dataset group by Stock_Index, Daily_low order by total_revenue desc;


SELECT Stock_Index, Daily_Low, MAX(Open_Price) AS total_revenue 
FROM finance_economics_dataset 
GROUP BY Stock_Index, Daily_Low 
ORDER BY total_revenue DESC;

