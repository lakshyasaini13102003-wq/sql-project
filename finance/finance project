select Open_price,avg (Close_Price) as Total_Revenue from finance_economics_dataset group by Open_Price;

select Open_price,count (Close_Price) as Total_Revenue from finance_economics_dataset group by Open_Price;--

select Open_price,sum (Close_Price) as Total_Revenue from finance_economics_dataset group by Open_Price;

