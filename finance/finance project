--data cleaning--

select* from finance_economics_dataset where date is null or Stock_Index is null or Open_Price is null or Close_Price is null or Daily_High is null or Daily_Low is null or Trading_Volume IS NULL OR GDP_Growth is null or Inflation_Rate is null or Unemployment_Rate is null or Interest_Rate is null or Consumer_Confidence_Index is null or Government_Debt_Billion_USD is null or Corporate_Profits_Billion_USD is null or Forex_USD_EUR is null or Forex_USD_JPY is null or Crude_Oil_Price_USD_per_Barrel is null or Gold_Price_USD_per_Ounce is  null or Real_Estate_Index is null or Retail_Sales_Billion_USD is null or Bankruptcy_Rate is null or Mergers_Acquisitions_Deals is  null or Venture_Capital_Funding_Billion_USD is null  or Consumer_Spending_Billion_USD is null;

-- window function--
select *, Row_number () over ( order by Open_Price desc) as rn_number from finance_economics_dataset;
-- lag-- datat of previous days --

select Date,Close_price ,lag ( Close_Price ) over ( order by Date) as prev_price from finance_economics_dataset;
-- price day to day change --

select Date,Close_price ,lag ( Close_Price ) over ( order by Date) as change_price from finance_economics_dataset;
-- rank-- function --

select Date,Close_price ,rank  ()over ( order by Close_price desc) as  price_rank from finance_economics_dataset;
select Date,Close_price ,rank  ()over ( order by Close_price desc) as  performance_rank from finance_economics_dataset;

-- dence rank--

select Date,Close_price, dense_rank () over (order by Close_price desc)  as dense_rank_price from  finance_economics_dataset; 


